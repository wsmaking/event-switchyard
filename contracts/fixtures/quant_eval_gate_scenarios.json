        "restingQty": {
          "eq": 0
        },
        "averageScoreBps": {
          "eq": 0
        },
        "recordScoreBps": {
          "eq": 0
        },
        "effectiveRiskBudgetRef": "budget-export-1",
        "modelId": "model-export-1"
      }
    },
