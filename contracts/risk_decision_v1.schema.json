{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Risk Decision Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "owner",
    "cases"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scope",
          "input",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "enum": [
              "v3_hot_risk"
            ]
          },
          "input": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "symbol",
              "side",
              "orderType",
              "qty",
              "price",
              "strictSymbols",
              "symbolKnown"
            ],
            "properties": {
              "symbol": {
                "type": "string",
                "minLength": 1
              },
              "side": {
                "type": "string",
                "minLength": 1
              },
              "orderType": {
                "type": "string",
                "minLength": 1
              },
              "qty": {
                "type": "integer",
                "minimum": 0
              },
              "price": {
                "type": "integer",
                "minimum": 0
              },
              "strictSymbols": {
                "type": "boolean"
              },
              "symbolKnown": {
                "type": "boolean"
              }
            }
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "allowed",
              "reason",
              "httpStatus"
            ],
            "properties": {
              "allowed": {
                "type": "boolean"
              },
              "reason": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "INVALID_QTY",
                  "INVALID_SIDE",
                  "INVALID_PRICE",
                  "INVALID_SYMBOL",
                  "RISK_REJECT"
                ]
              },
              "httpStatus": {
                "type": "integer",
                "enum": [
                  202,
                  422
                ]
              }
            }
          }
        }
      }
    }
  }
}
