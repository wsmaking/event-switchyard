{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Position Cap Decision Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "owner",
    "cases"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scope",
          "input",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "enum": [
              "position_cap_v1"
            ]
          },
          "input": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "symbol",
              "side",
              "qty",
              "currentPositionQty",
              "maxAbsPositionQty"
            ],
            "properties": {
              "symbol": {
                "type": "string",
                "minLength": 1
              },
              "side": {
                "type": "string",
                "minLength": 1
              },
              "qty": {
                "type": "integer",
                "minimum": 0
              },
              "currentPositionQty": {
                "type": "integer"
              },
              "maxAbsPositionQty": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "allowed",
              "reason",
              "httpStatus",
              "projectedPositionQty"
            ],
            "properties": {
              "allowed": {
                "type": "boolean"
              },
              "reason": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "POSITION_LIMIT_EXCEEDED",
                  "INVALID_QTY",
                  "INVALID_SIDE"
                ]
              },
              "httpStatus": {
                "type": "integer",
                "enum": [
                  202,
                  422
                ]
              },
              "projectedPositionQty": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  }
}
