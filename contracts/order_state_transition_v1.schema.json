{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order State Transition Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "owner",
    "transitions"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "from",
          "event",
          "filledQtyBefore",
          "filledQtyReported",
          "orderQty",
          "to",
          "invariant"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "enum": [
              "ACCEPTED",
              "SENT",
              "CANCEL_REQUESTED",
              "PARTIALLY_FILLED",
              "FILLED",
              "CANCELED",
              "REJECTED"
            ]
          },
          "event": {
            "type": "string",
            "enum": [
              "CANCEL_REQUESTED",
              "EXEC_REPORT_PARTIAL",
              "EXEC_REPORT_FILLED",
              "EXEC_REPORT_CANCELED",
              "EXEC_REPORT_REJECTED"
            ]
          },
          "filledQtyBefore": {
            "type": "integer",
            "minimum": 0
          },
          "filledQtyReported": {
            "type": "integer",
            "minimum": 0
          },
          "orderQty": {
            "type": "integer",
            "minimum": 1
          },
          "to": {
            "type": "string",
            "enum": [
              "ACCEPTED",
              "SENT",
              "CANCEL_REQUESTED",
              "PARTIALLY_FILLED",
              "FILLED",
              "CANCELED",
              "REJECTED"
            ]
          },
          "invariant": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
